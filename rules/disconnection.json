{
  "name": "disconnection",
  "focus": "Disconnection analysis",

  "detect": {
    "activity": [
      "Remove Device",
      "Unpair Device",
      "HCI Event: Disconnec",
      "Reason:.*Connection Terminated",
      "Reason:.*Remote User Terminated",
      "L2CAP: Disconnection Request",
      "PSM 17"
    ],
    "errors": [
      "Remove Device",
      "Unpair Device",
      "Reason:(?!.*(Remote User|Connection Terminated By Local Host|Success))"
    ]
  },

  "annotate": {
    "match_rules": [
      {
        "id": "connection_success",
        "direction": ">",
        "match": {"field": "full", "all_of": ["Connection Complete", "Success"]},
        "tags": ["HCI"],
        "annotation": "Connection: Success",
        "exclusive": true
      },
      {
        "id": "connection_fail",
        "direction": ">",
        "match": {"field": "full", "contains": "Connection Complete", "not_contains": "Success"},
        "tags": ["HCI"],
        "annotation": "Connection: FAIL",
        "exclusive": true
      },
      {
        "id": "supervision_timeout",
        "match": {"field": "body", "contains": "Supervision Timeout"},
        "tags": ["HCI"],
        "annotation": "Supervision timeout parameter",
        "exclusive": true
      },
      {
        "id": "connection_timeout",
        "direction": ">",
        "match": {"field": "full", "contains": "Connection Timeout"},
        "tags": ["HCI"],
        "annotation": "Connection timeout",
        "exclusive": true
      },
      {
        "id": "remove_device",
        "direction": "@",
        "match": {"field": "full", "contains": "Remove Device"},
        "tags": ["MGMT"],
        "annotation": "MGMT: Remove Device",
        "exclusive": true
      },
      {
        "id": "unpair_device",
        "direction": "@",
        "match": {"field": "full", "contains": "Unpair Device"},
        "tags": ["MGMT"],
        "annotation": "MGMT: Unpair Device",
        "exclusive": true
      },
      {
        "id": "hidp_data",
        "match": {"field": "full", "contains": "PSM 17"},
        "tags": ["HID"],
        "annotation": "HIDP data (PSM 17)",
        "exclusive": true
      }
    ],
    "hooks": ["disconnect_classification"]
  },

  "diagnose": {
    "hooks": []
  }
}
