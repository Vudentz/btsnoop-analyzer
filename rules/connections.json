{
  "name": "connections",
  "focus": "Connection issues",

  "detect": {
    "activity": [
      "Connection Complete",
      "LE Connection Complete",
      "Enhanced LE Connection Complete",
      "Disconnect"
    ],
    "errors": [
      "Connection Complete.*Status:(?!.*Success)",
      "LE Connection Complete.*Status:(?!.*Success)",
      "Disconnect.*Reason:",
      "Connection Timeout",
      "Connection Failed",
      "Auth Complete.*Status:(?!.*Success)",
      "Authentication Failed"
    ]
  },

  "annotate": {
    "match_rules": [
      {
        "id": "conn_update",
        "direction": ">",
        "match": {"field": "full", "contains": "Connection Update"},
        "tags": ["HCI"],
        "annotation": "Connection parameters updated",
        "exclusive": true
      },
      {
        "id": "data_length_change",
        "direction": ">",
        "match": {"field": "full", "contains": "Data Length Change"},
        "tags": ["HCI"],
        "annotation": "Data length changed",
        "exclusive": true
      },
      {
        "id": "remote_features",
        "direction": ">",
        "match": {"field": "full", "contains": "Read Remote Used Features"},
        "tags": ["HCI"],
        "annotation": "Remote features read",
        "exclusive": true
      },
      {
        "id": "conn_timeout_fail",
        "direction": ">",
        "match": {"field": "full", "any_of": ["Connection Timeout", "Connection Failed"]},
        "tags": ["HCI"],
        "annotation": "Connection failure/timeout",
        "exclusive": true
      }
    ],
    "hooks": ["connections_complete", "disconnect_classification"]
  },

  "diagnose": {
    "hooks": []
  }
}
